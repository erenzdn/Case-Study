# =============================================================================
# LLM-Based Database Data Discovery System (Java/Spring Boot) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# System Database (stores metadata & classification results)
# -----------------------------------------------------------------------------
SYSTEM_DB_HOST=system_db
SYSTEM_DB_PORT=5432
SYSTEM_DB_NAME=system_database
SYSTEM_DB_USER=postgres
SYSTEM_DB_PASSWORD=postgres123

# -----------------------------------------------------------------------------
# Authentication (Basic Auth credentials for POST /auth)
# -----------------------------------------------------------------------------
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123

# -----------------------------------------------------------------------------
# JWT Token Configuration
# JWT is returned by POST /auth and required as Bearer token for all other endpoints
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_EXPIRATION_MINUTES=60

# -----------------------------------------------------------------------------
# OpenAI Compatible API (required for POST /classify endpoint)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
